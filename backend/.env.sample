# Claude API
CLAUDE_API_KEY=sk-ant-여기에입력

# Kakao OAuth (현재 사용)
KAKAO_CLIENT_ID=여기에입력
KAKAO_CLIENT_SECRET=여기에입력

# Google OAuth (나중에 추가)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=최소32자이상의랜덤문자열로변경필수

# Database
# docker-compose로 실행 시 호스트 포트가 5433 (로컬에 이미 설치된 Postgres와 충돌 방지)
# EC2 배포 시에는 RDS 엔드포인트로 변경: jdbc:postgresql://<RDS엔드포인트>:5432/career_db
DB_URL=jdbc:postgresql://localhost:5433/career_db
DB_USERNAME=postgres
DB_PASSWORD=your_password

# 로그인 성공 후 토큰을 들고 돌아갈 프론트 주소 (배포 시 실제 프론트 도메인으로 변경)
FRONTEND_REDIRECT_URI=http://localhost:3000/oauth/callback

# CORS 허용 origin (콤마 구분, 배포 시 실제 프론트 도메인 추가)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app
